---
import { Icon } from "astro-icon/components";
import { socialIconName } from "../lib/social";

const { socials, email } = Astro.props;

const year = new Date().getFullYear();
---

<div class="bg-ink text-paper">
    <div class="mx-auto max-w-5xl px-6">
        <div
            class="flex flex-col items-center gap-6 border-t border-paper/10 py-10 text-center"
        >
            <nav
                aria-label="Social links"
                class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm"
            >
                {
                    socials?.map((social: { label: string; url: string }) => (
                        <a
                            href={social.url}
                            target="_blank"
                            rel="noreferrer"
                            class="inline-flex items-center gap-2 text-paper/70 transition hover:text-paper"
                        >
                            <Icon
                                name={socialIconName(social.label)}
                                class="h-4 w-4"
                            />
                            <span>{social.label}</span>
                            <span class="sr-only"> (opens in new tab)</span>
                        </a>
                    ))
                }
                {
                    email ? (
                        <a
                            href={`mailto:${email}`}
                            class="inline-flex items-center gap-2 text-paper/70 transition hover:text-paper"
                        >
                            <Icon name="mdi:email-outline" class="h-4 w-4" />
                            <span>{email}</span>
                        </a>
                    ) : null
                }
            </nav>
            <p class="text-xs italic text-paper/40">© {year} John Cavanagh</p>
            <p
                class="flex flex-wrap items-center justify-center gap-x-2 gap-y-1 text-xs text-paper/30"
            >
                <span>Built with</span>
                <a
                    href="https://astro.build"
                    target="_blank"
                    rel="noreferrer"
                    class="text-paper/50 underline underline-offset-2 transition hover:text-paper/80"
                >
                    Astro
                </a>
                <span class="text-paper/20">·</span>
                <a
                    href="https://github.com/johncavpub/johncavpub.com"
                    target="_blank"
                    rel="noreferrer"
                    class="inline-flex items-center gap-1 text-paper/50 transition hover:text-paper/80"
                >
                    <Icon name="mdi:github" class="h-3.5 w-3.5" />
                    <span>GitHub</span>
                </a>
            </p>
        </div>
    </div>
</div>

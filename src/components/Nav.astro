---
const { shopUrl, showBooks, currentPath = "/" } = Astro.props;

const isActive = (path: string) => {
  if (path === "/") return currentPath === "/";
  return currentPath === path || currentPath.startsWith(`${path}/`);
};

const navItems: { label: string; href: string; external?: boolean }[] = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  ...(showBooks ? [{ label: "Books", href: "/books" }] : []),
  { label: "Events", href: "/events" },
  { label: "Contact", href: "/contact" },
  { label: "Shop", href: shopUrl, external: true },
];
---

<header class="border-b border-rule">
  <div class="mx-auto max-w-5xl px-6 pt-7 pb-5 sm:pt-12 sm:pb-8">
    <div class="flex items-center justify-between sm:flex-col sm:gap-6">
      <a
        href="/"
        class="display-tight text-2xl sm:text-4xl font-medium tracking-tight text-ink"
      >
        John Cavanagh
      </a>

      <button
        id="menu-toggle"
        type="button"
        class="sm:hidden inline-flex items-center justify-center rounded-md p-2 text-ink-muted hover:bg-paper-deep hover:text-ink transition"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg
          id="menu-icon"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
        <svg
          id="close-icon"
          class="hidden h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <nav
      id="mobile-menu"
      aria-label="Primary"
      class="hidden sm:flex sm:flex-row sm:justify-center sm:items-center sm:gap-x-8 mt-6 text-[0.7rem] font-semibold uppercase tracking-[0.24em] text-ink-muted"
    >
      {navItems.map((item) => {
        const active = !item.external && isActive(item.href);
        return item.external ? (
          <a
            class="inline-flex items-center gap-1 transition hover:text-ink"
            href={item.href}
            target="_blank"
            rel="noreferrer"
          >
            {item.label} <span aria-hidden="true" class="text-ink-faint">↗</span>
          </a>
        ) : (
          <a
            class:list={[
              "transition",
              active ? "text-ink" : "hover:text-ink",
            ]}
            href={item.href}
            aria-current={active ? "page" : undefined}
          >
            <span
              class:list={[
                active ? "border-b border-ink pb-1" : "border-b border-transparent pb-1",
              ]}
            >
              {item.label}
            </span>
          </a>
        );
      })}
    </nav>
  </div>

  <!-- Full-screen mobile menu -->
  <div
    id="mobile-menu-overlay"
    class="fixed inset-0 z-50 hidden bg-paper sm:hidden"
  >
    <div class="flex h-full flex-col">
      <div
        class="flex items-center justify-between border-b border-rule px-6 py-7"
      >
        <a href="/" class="display-tight text-2xl font-medium tracking-tight text-ink">
          John Cavanagh
        </a>
        <button
          id="mobile-close"
          type="button"
          class="inline-flex items-center justify-center rounded-md p-2 text-ink-muted hover:bg-paper-deep hover:text-ink transition"
          aria-label="Close menu"
        >
          <svg
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <nav
        aria-label="Mobile navigation"
        class="flex flex-1 flex-col items-center justify-center gap-7 text-base font-semibold uppercase tracking-[0.24em] text-ink"
      >
        {navItems.map((item) =>
          item.external ? (
            <a
              class="inline-flex items-center gap-2 hover:text-ink-muted transition"
              href={item.href}
              target="_blank"
              rel="noreferrer"
            >
              {item.label} <span aria-hidden="true">↗</span>
            </a>
          ) : (
            <a class="hover:text-ink-muted transition" href={item.href}>
              {item.label}
            </a>
          ),
        )}
      </nav>
    </div>
  </div>
</header>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenuOverlay = document.getElementById("mobile-menu-overlay");
  const mobileClose = document.getElementById("mobile-close");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  function openMenu() {
    menuToggle?.setAttribute("aria-expanded", "true");
    mobileMenuOverlay?.classList.remove("hidden");
    menuIcon?.classList.add("hidden");
    closeIcon?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    menuToggle?.setAttribute("aria-expanded", "false");
    mobileMenuOverlay?.classList.add("hidden");
    menuIcon?.classList.remove("hidden");
    closeIcon?.classList.add("hidden");
    document.body.style.overflow = "";
  }

  menuToggle?.addEventListener("click", openMenu);
  mobileClose?.addEventListener("click", closeMenu);

  const mobileLinks = mobileMenuOverlay?.querySelectorAll("a");
  mobileLinks?.forEach((link) => {
    link.addEventListener("click", closeMenu);
  });
</script>

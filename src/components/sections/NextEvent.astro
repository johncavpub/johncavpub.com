---
const { events, windowDays = 60 } = Astro.props;

const now = new Date();
const windowEnd = new Date(now);
windowEnd.setDate(windowEnd.getDate() + windowDays);

const upcomingEvents = (events ?? [])
  .map((event) => ({
    ...event,
    parsedDate: new Date(event.data.date),
  }))
  .filter((event) => event.parsedDate >= now && event.parsedDate <= windowEnd)
  .sort((a, b) => a.parsedDate.getTime() - b.parsedDate.getTime());

const nextEvent = upcomingEvents[0];
---

{
  nextEvent ? (
    <section class="mx-auto max-w-5xl px-4 pb-6 pt-8 sm:px-6 sm:pt-10">
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
          Upcoming event
        </p>
        <h2 class="mt-2 text-xl font-semibold text-slate-900">
          {nextEvent.data.title}
        </h2>
        <p class="mt-2 text-sm text-slate-600">
          {nextEvent.data.date} · {nextEvent.data.location}
        </p>
        {nextEvent.data.description ? (
          <p class="mt-3 text-base text-slate-700">
            {nextEvent.data.description}
          </p>
        ) : null}
        <a
          class="mt-4 inline-flex items-center text-sm font-semibold text-slate-900 hover:text-slate-700"
          href={nextEvent.data.url}
          target="_blank"
          rel="noreferrer"
        >
          View details
        </a>
      </div>
    </section>
  ) : null
}

---
const { events, windowDays = 60 } = Astro.props;

const now = new Date();
const windowEnd = new Date(now);
windowEnd.setDate(windowEnd.getDate() + windowDays);

const upcomingEvents = (events ?? [])
  .map((event) => ({
    ...event,
    parsedDate: new Date(event.data.date),
  }))
  .filter((event) => event.parsedDate >= now && event.parsedDate <= windowEnd)
  .sort((a, b) => a.parsedDate.getTime() - b.parsedDate.getTime());

const nextEvent = upcomingEvents[0];

const formattedDate = nextEvent
  ? nextEvent.parsedDate.toLocaleDateString("en-US", {
      month: "long",
      day: "numeric",
      year: "numeric",
      timeZone: "UTC",
    })
  : null;
---

{
  nextEvent ? (
    <section class="mx-auto max-w-3xl px-6 pt-2 pb-12 sm:pb-16">
      <div class="border-y border-rule py-8 sm:py-10 text-center">
        <p class="eyebrow">Upcoming event</p>
        <h2 class="mt-4 display-tight text-2xl sm:text-3xl font-medium text-ink">
          {nextEvent.data.title}
        </h2>
        <p class="mt-3 text-sm text-ink-muted">
          <span class="italic">{formattedDate}</span>
          <span class="mx-2 text-ink-faint" aria-hidden="true">·</span>
          {nextEvent.data.location}
        </p>
        {nextEvent.data.description ? (
          <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-ink-muted">
            {nextEvent.data.description}
          </p>
        ) : null}
        {nextEvent.data.url ? (
          <a
            class="mt-6 inline-block eyebrow link-underline text-ink hover:text-accent transition"
            href={nextEvent.data.url}
            target="_blank"
            rel="noreferrer"
          >
            View details
          </a>
        ) : null}
      </div>
    </section>
  ) : null
}

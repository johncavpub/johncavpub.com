---
const { siteName = "John Cavanagh", intro } = Astro.props;
---

<section class="mx-auto max-w-4xl px-6 pt-12 pb-10 sm:pt-20 sm:pb-16 text-center">
    <h1 class="sr-only">{siteName}</h1>
    {
        intro ? (
            <>
                <p class="display-tight text-2xl sm:text-3xl md:text-4xl leading-tight font-medium italic text-ink">
                    {intro}
                </p>
                <div class="mx-auto mt-10 h-px w-16 bg-rule" aria-hidden="true" />
            </>
        ) : null
    }
</section>

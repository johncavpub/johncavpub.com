---
import Flourish from "../Flourish.astro";

const { siteName = "John Cavanagh", intro } = Astro.props;
---

<section class="mx-auto max-w-4xl px-6 pt-12 pb-10 sm:pt-20 sm:pb-16 text-center">
    <h1 class="sr-only">{siteName}</h1>
    {
        intro ? (
            <>
                <p class="display-tight text-3xl sm:text-4xl md:text-5xl leading-tight font-medium italic text-ink text-balance">
                    {intro}
                </p>
                <Flourish class="mt-10" />
            </>
        ) : null
    }
</section>

---
import BookCover from "../BookCover.astro";
import { orderBooks } from "../../lib/books";
import { formatDate } from "../../lib/format";

const { books } = Astro.props;

const ordered = orderBooks(books ?? []);
---

<section class="divide-y divide-rule border-y border-rule">
  {
    ordered.map(({ book, comingSoon }) => (
      <a
        class="group block py-8 sm:py-10 transition hover:bg-paper-soft"
        href={`/books/${book.slug}`}
      >
        <article class="grid gap-6 sm:grid-cols-[160px_1fr] sm:gap-10 px-2">
          <BookCover
            title={book.data.title}
            src={book.data.cover_image}
            width={400}
            widths={[320, 480, 640]}
            sizes="160px"
            hover
          />
          <div>
            <div class="flex flex-wrap items-baseline gap-3">
              <h2 class="display-tight text-2xl sm:text-3xl font-medium text-ink group-hover:text-accent transition">
                {book.data.title}
              </h2>
              {comingSoon ? (
                <span class="eyebrow text-accent">Coming soon</span>
              ) : null}
            </div>
            {formatDate(book.data.publish_date) ? (
              <p class="mt-1 text-sm italic text-ink-faint">
                {formatDate(book.data.publish_date)}
              </p>
            ) : null}
            <p class="mt-4 text-base leading-relaxed text-ink-muted">
              {book.data.description}
            </p>
            <span class="mt-5 inline-block eyebrow link-underline text-ink group-hover:text-accent transition">
              Read more
            </span>
          </div>
        </article>
      </a>
    ))
  }
</section>

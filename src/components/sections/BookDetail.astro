---
import BookCover from "../BookCover.astro";
import Button from "../Button.astro";
import Flourish from "../Flourish.astro";
import { formatDate } from "../../lib/format";

const { book, Content } = Astro.props;

const formattedDate = formatDate(book.data.publish_date);
---

<section class="mx-auto max-w-5xl px-6 pt-10 pb-20 sm:pt-16">
  <div
    class="grid items-start justify-items-center gap-12 sm:gap-20 lg:grid-cols-[minmax(0,280px)_1fr] lg:justify-items-start"
  >
    <div class="w-full max-w-64">
      <BookCover
        title={book.data.title}
        src={book.data.cover_image}
        width={520}
        widths={[320, 520, 720]}
        sizes="(min-width: 1024px) 260px, 80vw"
        loading="eager"
      />
    </div>
    <div class="w-full max-w-xl">
      <h1 class="display-tight text-3xl sm:text-4xl font-medium text-ink">
        {book.data.title}
      </h1>
      {formattedDate ? (
        <p class="mt-3 text-sm italic text-ink-faint">{formattedDate}</p>
      ) : null}
      <div
        class="mt-8 space-y-5 text-lg leading-relaxed text-ink-muted [&_em]:text-ink"
      >
        <Content />
      </div>
      <Flourish align="left" class="mt-8" />
      <div class="mt-8 flex flex-wrap gap-3">
        {book.data.amazon_url && (
          <Button href={book.data.amazon_url} external>
            Amazon
          </Button>
        )}
        {book.data.barnes_noble_url && (
          <Button href={book.data.barnes_noble_url} variant="outline" external>
            Barnes & Noble
          </Button>
        )}
      </div>
    </div>
  </div>
</section>

---
import TestimonialsCarouselVue from "../TestimonialsCarousel.vue";

interface Testimonial {
  author: string;
  quote: string;
  role?: string;
  source?: string;
}

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;
---

<section class="border-t border-rule bg-paper-soft">
  <div class="mx-auto max-w-5xl px-6 py-16 sm:py-20">
    <h2 class="eyebrow mb-10 text-center">Praise</h2>
    <TestimonialsCarouselVue client:load testimonials={testimonials} />
  </div>
</section>

---
import TestimonialsCarouselVue from "../TestimonialsCarousel.vue";

interface Testimonial {
  data: {
    author: string;
    quote: string;
    role?: string;
    source?: string;
  };
}

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;

const testimonialsData = testimonials.map((t) => ({
  author: t.data.author,
  quote: t.data.quote,
  role: t.data.role,
  source: t.data.source,
}));
---

<section class="border-t border-rule bg-paper-soft">
  <div class="mx-auto max-w-5xl px-6 py-16 sm:py-20">
    <div class="mb-10 text-center">
      <p class="eyebrow">Praise</p>
    </div>
    <TestimonialsCarouselVue client:load testimonials={testimonialsData} />
  </div>
</section>

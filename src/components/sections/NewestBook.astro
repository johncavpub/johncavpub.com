---
import BookCover from "../BookCover.astro";
import { orderBooks } from "../../lib/books";
import { formatDate } from "../../lib/format";

const { books } = Astro.props;

const ordered = orderBooks(books ?? []);
const count = ordered.length;
const single = count === 1;

const gridCols =
  count === 2
    ? "grid-cols-2"
    : count === 3
      ? "grid-cols-2 sm:grid-cols-3"
      : "grid-cols-2 lg:grid-cols-4";

// Cap the grid width so covers stay a sensible size when there are
// only one or two books, instead of stretching across the section.
const gridMaxWidth =
  count === 1
    ? "max-w-xs"
    : count === 2
      ? "max-w-lg"
      : count === 3
        ? "max-w-3xl"
        : "max-w-5xl";
---

{
  count ? (
    <section class="mx-auto max-w-5xl px-6 pt-4 pb-16 sm:pb-20">
      <h2 class="eyebrow mb-10 text-center">
        {single ? "Latest book" : "Featured books"}
      </h2>
      <div
        class:list={[
          "grid gap-10 sm:gap-12 mx-auto",
          gridMaxWidth,
          single ? "grid-cols-1 justify-items-center" : gridCols,
        ]}
      >
        {ordered.map(({ book, comingSoon }) => (
          <a
            href={`/books/${book.slug}`}
            class:list={["group block text-center", single ? "max-w-xs" : ""]}
          >
            <BookCover
              title={book.data.title}
              src={book.data.cover_image}
              width={600}
              widths={[400, 600, 800, 1200]}
              sizes="(min-width: 1024px) 320px, (min-width: 640px) 33vw, 50vw"
              hover
              comingSoon={comingSoon}
            />
            <h3
              class="mt-5 display-tight text-lg sm:text-xl font-medium text-ink group-hover:text-accent transition text-balance leading-snug"
            >
              {book.data.title}
            </h3>
            {formatDate(book.data.publish_date, "monthYear") ? (
              <p class="mt-1 text-xs italic text-ink-faint">
                {formatDate(book.data.publish_date, "monthYear")}
              </p>
            ) : null}
          </a>
        ))}
      </div>
    </section>
  ) : null
}

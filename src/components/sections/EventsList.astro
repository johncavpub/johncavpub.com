---
import { formatDate } from "../../lib/format";

const { events } = Astro.props;

const now = new Date();
const annotated = (events ?? []).map((event) => ({
    event,
    isPast: new Date(event.date) < now,
    formattedDate: formatDate(event.date, "short"),
}));
---

<section class="divide-y divide-rule border-y border-rule">
    {
        annotated.map(({ event, isPast, formattedDate }) => {
            const content = (
                <article
                    class:list={[
                        "py-10 text-center sm:py-12",
                        isPast ? "opacity-55" : "",
                    ]}
                >
                    <p class="eyebrow">
                        {isPast ? `Past · ${formattedDate}` : formattedDate}
                    </p>
                    <h2 class="mt-4 display-tight text-2xl sm:text-3xl font-medium text-ink group-hover:text-accent transition">
                        {event.title}
                    </h2>
                    <p class="mt-3 text-sm text-ink-muted">
                        {event.time ? (
                            <>
                                {event.time}
                                <span
                                    class="mx-2 text-ink-faint"
                                    aria-hidden="true"
                                >
                                    ·
                                </span>
                            </>
                        ) : null}
                        {event.location}
                    </p>
                    {event.address ? (
                        <p class="mt-1 text-sm text-ink-faint">
                            {event.address}
                        </p>
                    ) : null}
                    {event.description ? (
                        <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-ink-muted">
                            {event.description}
                        </p>
                    ) : null}
                    {event.url && !isPast ? (
                        <span class="mt-6 inline-block eyebrow link-underline text-ink group-hover:text-accent transition">
                            View details
                        </span>
                    ) : null}
                </article>
            );

            return event.url ? (
                <a
                    class="group block transition hover:bg-paper-soft"
                    href={event.url}
                    target="_blank"
                    rel="noreferrer"
                >
                    {content}
                </a>
            ) : (
                <div>{content}</div>
            );
        })
    }
</section>

---
import { getCollection, getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import HomeHero from "../components/sections/HomeHero.astro";
import NewestBook from "../components/sections/NewestBook.astro";
import NextEvent from "../components/sections/NextEvent.astro";
import TestimonialsCarousel from "../components/sections/TestimonialsCarousel.astro";

const site = await getEntry("site", "site");

if (!site) {
    throw new Error("Site content not found.");
}

const books = await getCollection("books", ({ data }) => !data.draft);
const eventsEntry = await getEntry("events", "events");
const events = eventsEntry?.data ?? [];
const testimonialsEntry = await getEntry("testimonials", "testimonials");
const testimonials = testimonialsEntry?.data ?? [];
const highlightedBooks = books
    .filter((book) => book.data.highlight)
    .sort(
        (a, b) =>
            (b.data.publish_date ? Date.parse(b.data.publish_date) : 0) -
            (a.data.publish_date ? Date.parse(a.data.publish_date) : 0),
    );
---

<Layout title={site.data.author_name} description={site.data.site_tagline}>
    <HomeHero intro={site.data.site_tagline} />
    <NextEvent events={events} />
    <NewestBook books={highlightedBooks} />
    {
        testimonials.length ? (
            <TestimonialsCarousel testimonials={testimonials} />
        ) : null
    }
</Layout>

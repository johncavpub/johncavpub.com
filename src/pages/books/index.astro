---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import BooksList from "../../components/sections/BooksList.astro";

// BooksList handles display ordering (released newest-first, then upcoming).
const books = await getCollection("books", ({ data }) => !data.draft);

if (books.length < 2) {
  return Astro.redirect("/");
}
---

<Layout
  title="Books"
  description="Browse the full catalog of books by John Cavanagh, including the Riddler Rabbit series."
>
  <div class="mx-auto max-w-3xl px-6 pt-10 pb-20 sm:pt-16">
    <PageHeader title="Books" subtitle="Browse the full catalog of titles." />

    <BooksList books={books} />
  </div>
</Layout>

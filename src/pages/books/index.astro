---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import BooksList from "../../components/sections/BooksList.astro";

const now = Date.now();
const all = await getCollection("books", ({ data }) => !data.draft);

const annotated = all.map((book) => ({
  book,
  ts: book.data.publish_date ? Date.parse(book.data.publish_date) : 0,
  comingSoon: book.data.publish_date
    ? Date.parse(book.data.publish_date) > now
    : false,
}));

const released = annotated
  .filter((b) => !b.comingSoon)
  .sort((a, b) => b.ts - a.ts);
const upcoming = annotated
  .filter((b) => b.comingSoon)
  .sort((a, b) => a.ts - b.ts);

const books = [...released, ...upcoming].map((b) => b.book);

if (books.length < 2) {
  return Astro.redirect("/");
}
---

<Layout
  title="Books"
  description="Browse the full catalog of books by John Cavanagh, including the Riddler Rabbit series."
>
  <div class="mx-auto max-w-3xl px-6 pt-10 pb-20 sm:pt-16">
    <header class="mb-10 text-center">
      <h1 class="display-tight text-4xl sm:text-5xl font-medium text-ink">
        Books
      </h1>
      <p class="mt-4 text-base italic text-ink-muted">
        Browse the full catalog of titles.
      </p>
    </header>

    <BooksList books={books} />
  </div>
</Layout>

---
import { getCollection, getEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import BookDetail from "../../components/sections/BookDetail.astro";

export async function getStaticPaths() {
  const books = await getCollection("books");
  return books.map((book) => ({ params: { slug: book.slug } }));
}

const { slug } = Astro.params;
const book = await getEntry("books", slug ?? "");
if (!book) {
  throw new Error("Book not found.");
}
const { Content } = await book.render();
---

<Layout title={book.data.title}>
  <BookDetail book={book} Content={Content} />
</Layout>

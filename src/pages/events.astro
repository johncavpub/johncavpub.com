---
import { getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import EventsList from "../components/sections/EventsList.astro";

const now = Date.now();
const eventsEntry = await getEntry("events", "events");
const events = (eventsEntry?.data ?? [])
  .map((event) => ({ event, ts: new Date(event.date).getTime() }))
  .sort((a, b) => {
    const aPast = a.ts < now;
    const bPast = b.ts < now;
    // Upcoming events first, then past; within each group, by date ascending.
    if (aPast !== bPast) return aPast ? 1 : -1;
    return a.ts - b.ts;
  })
  .map(({ event }) => event);
---

<Layout
  title="Events"
  description="Upcoming appearances, book signings, and events with John Cavanagh."
>
  <div class="mx-auto max-w-3xl px-6 pt-10 pb-20 sm:pt-16">
    <PageHeader title="Events" subtitle="Upcoming appearances and signings." />

    {
      events.length ? (
        <EventsList events={events} />
      ) : (
        <p class="text-center text-base italic text-ink-muted">
          Event details will be posted soon.
        </p>
      )
    }
  </div>
</Layout>

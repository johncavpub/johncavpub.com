---
import Layout from "../layouts/Layout.astro";
import { getEntry } from "astro:content";

const contactEntry = await getEntry("contact", "contact");
const { Content } = await contactEntry.render();
const contact = contactEntry.data;
---

<Layout title="Contact" description={contact.intro}>
  <div class="mx-auto max-w-2xl px-6 pt-10 pb-20 sm:pt-16">
    <header class="mb-10 text-center">
      <h1 class="display-tight text-4xl sm:text-5xl font-medium text-ink">
        {contact.title}
      </h1>
      <p class="mt-4 text-base italic text-ink-muted">
        {contact.intro}
      </p>
    </header>

    <div class="space-y-8">
      <div
        class="border-y border-rule py-8 text-center"
      >
        <p class="eyebrow">Email</p>
        <a
          href={`mailto:${contact.email}`}
          class="mt-3 inline-block display-tight text-xl sm:text-2xl font-medium text-ink hover:text-accent transition"
        >
          {contact.email}
        </a>
      </div>

      <div
        class="prose prose-slate max-w-none text-center text-base leading-relaxed text-ink-muted"
      >
        <Content />
      </div>

      {
        contact.response_time ? (
          <p class="text-center text-sm italic text-ink-faint">
            {contact.response_time}
          </p>
        ) : null
      }
    </div>
  </div>
</Layout>

---
import { getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";

const site = await getEntry("site", "site");
if (!site) throw new Error("Site content not found.");
const contact = site.data;
---

<Layout title="Contact" description={contact.contact_page_intro}>
  <section class="mx-auto max-w-2xl px-6 pt-10 pb-20 sm:pt-16">
    <PageHeader title="Get in Touch" subtitle={contact.contact_page_intro} />

    <div class="space-y-8">
      <div class="border-y border-rule py-8 text-center">
        <p class="eyebrow">Email</p>
        <a
          href={`mailto:${contact.contact_email}`}
          class="mt-3 inline-block display-tight text-xl sm:text-2xl font-medium text-ink hover:text-accent transition"
        >
          {contact.contact_email}
        </a>
      </div>

      {
        contact.contact_page_body ? (
          <p class="text-center text-base leading-relaxed text-ink-muted">
            {contact.contact_page_body}
          </p>
        ) : null
      }

      {
        contact.contact_response_time ? (
          <p class="text-center text-sm italic text-ink-faint">
            {contact.contact_response_time}
          </p>
        ) : null
      }
    </div>
  </section>
</Layout>

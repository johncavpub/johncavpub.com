---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Thanks">
  <div class="mx-auto max-w-2xl px-6 pt-10 pb-20 sm:pt-16">
    <header class="mb-10 text-center">
      <h1 class="display-tight text-4xl sm:text-5xl font-medium text-ink">
        Thanks for subscribing
      </h1>
      <p class="mt-4 text-base italic text-ink-muted">
        You're on the list. Watch your inbox for the next note.
      </p>
    </header>

    <div class="text-center">
      <a
        href="/"
        class="inline-flex items-center justify-center rounded-full bg-ink px-7 py-3 text-xs font-semibold uppercase tracking-[0.22em] text-paper transition hover:bg-ink/90"
      >
        Back home
      </a>
    </div>
  </div>
</Layout>

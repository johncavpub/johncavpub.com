---
import { getCollection, getEntry } from "astro:content";
import Nav from "../components/Nav.astro";
import SubscribeForm from "../components/SubscribeForm.astro";
import "../styles/global.css";

const { title = "John Cavanagh" } = Astro.props;
const home = await getEntry("pages", "home");
const newsletterUrl =
  home?.data.newsletter_url ?? "https://example.com/newsletter";
const shopUrl = home?.data.redbubble_url ?? "https://example.com/shop";
const books = await getCollection("books");
const showBooks = books.length >= 3;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script
      defer
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"
    ></script>
  </head>
  <body>
    <Nav shopUrl={shopUrl} showBooks={showBooks} />
    <main class="pb-12 sm:pb-20">
      <slot />
    </main>
    <footer>
      <SubscribeForm newsletterUrl={newsletterUrl} />
    </footer>
  </body>
</html>

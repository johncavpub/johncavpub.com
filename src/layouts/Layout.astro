---
import { getCollection, getEntry } from "astro:content";
import Nav from "../components/Nav.astro";
import SubscribeForm from "../components/SubscribeForm.astro";
import FooterMeta from "../components/FooterMeta.astro";
import "../styles/global.css";

const { title = "John Cavanagh" } = Astro.props;
const home = await getEntry("pages", "home");
const about = await getEntry("pages", "about");
const contact = await getEntry("contact", "contact");
const shopUrl = home?.data.redbubble_url ?? "https://example.com/shop";
const socials = about?.data.socials ?? [];
const email = contact?.data.email;
const books = await getCollection("books");
const showBooks = books.length >= 3;
const currentPath = Astro.url.pathname;
const subscribed = currentPath.startsWith("/thanks");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script
      defer
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"
    ></script>
  </head>
  <body class="bg-paper text-ink">
    <Nav shopUrl={shopUrl} showBooks={showBooks} currentPath={currentPath} />
    <main class="pb-16 sm:pb-24">
      <slot />
    </main>
    <footer>
      <SubscribeForm subscribed={subscribed} />
      <FooterMeta socials={socials} email={email} />
    </footer>
  </body>
</html>

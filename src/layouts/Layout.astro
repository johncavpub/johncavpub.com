---
import { getCollection, getEntry } from "astro:content";
import Nav from "../components/Nav.astro";
import SubscribeForm from "../components/SubscribeForm.astro";
import FooterMeta from "../components/FooterMeta.astro";
import { imgUrl } from "../lib/cloudinary";
import "../styles/global.css";

const {
  title = "John Cavanagh",
  description: descriptionProp,
  ogImage: ogImageProp,
  ogType = "website",
} = Astro.props;
const site = await getEntry("site", "site");
const shopUrl = site?.data.redbubble_url ?? "https://example.com/shop";
const socials = site?.data.social_links ?? [];
const email = site?.data.contact_email;
const books = await getCollection("books", ({ data }) => !data.draft);
const showBooks = books.length >= 2;
const currentPath = Astro.url.pathname;
const subscribed = currentPath.startsWith("/thanks");

const siteDescription = site?.data.site_tagline ?? "Children's book author John Cavanagh.";
const description = descriptionProp ?? siteDescription;

const rawOgImage = ogImageProp ?? site?.data.author_headshot_image;
const ogImageUrl = rawOgImage
  ? imgUrl(rawOgImage, { w: 1200, h: 630, c: "pad", b: "rgb:f8f5ee" })
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="canonical" href={Astro.url.href} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="John Cavanagh" />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <script
      defer
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"
    ></script>
  </head>
  <body class="bg-paper text-ink">
    <Nav shopUrl={shopUrl} showBooks={showBooks} currentPath={currentPath} />
    <main class="pb-16 sm:pb-24">
      <slot />
    </main>
    <footer>
      <SubscribeForm subscribed={subscribed} />
      <FooterMeta socials={socials} email={email} />
    </footer>
  </body>
</html>
